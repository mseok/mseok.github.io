#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BUNDLER_VERSION="2.5.23"
BREW_FORMULAE=(libyaml openssl@3 readline gmp)

if ! command -v mise >/dev/null 2>&1; then
  echo "mise is required. Install it from https://mise.jdx.dev/ and rerun bin/setup."
  exit 1
fi

cd "$ROOT_DIR"
mise trust -y "$ROOT_DIR" >/dev/null 2>&1 || true

if command -v brew >/dev/null 2>&1; then
  missing=()
  for formula in "${BREW_FORMULAE[@]}"; do
    if ! brew list --versions "$formula" >/dev/null 2>&1; then
      missing+=("$formula")
    fi
  done

  if [ "${#missing[@]}" -gt 0 ]; then
    brew install "${missing[@]}"
  fi

  export PKG_CONFIG_PATH="$(brew --prefix libyaml)/lib/pkgconfig:${PKG_CONFIG_PATH:-}"
  export RUBY_CONFIGURE_OPTS="--with-libyaml-dir=$(brew --prefix libyaml) --with-openssl-dir=$(brew --prefix openssl@3) --with-readline-dir=$(brew --prefix readline) --with-gmp-dir=$(brew --prefix gmp)"
else
  echo "Homebrew was not found."
  echo "Install libyaml, openssl@3, readline, and gmp before running bin/setup."
  exit 1
fi

mise install

if ! mise exec -- bundle "_${BUNDLER_VERSION}_" -v >/dev/null 2>&1; then
  mise exec -- gem install bundler -v "${BUNDLER_VERSION}" --no-document
fi

mise exec -- bundle "_${BUNDLER_VERSION}_" install
